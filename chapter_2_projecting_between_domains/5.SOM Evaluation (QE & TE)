from minisom import MiniSom
import numpy as np
import matplotlib.pyplot as plt

# =====================================
# 1. Load data
# =====================================
data = np.load(r"D:\VECTORS\all_vectors.npy")

# =====================================
# 2. Normalize vectors (important)
# =====================================
data = data / np.linalg.norm(data, axis=1, keepdims=True)

# =====================================
# 3. Initialize SOM
# =====================================
som_size = 20

som = MiniSom(
    x=som_size,
    y=som_size,
    input_len=data.shape[1],
    sigma=1.0,
    learning_rate=0.5
)

# =====================================
# 4. Prepare evaluation lists
# =====================================
qe_list = []   # Quantization Error
te_list = []   # Topographic Error
som_list = []  # Store weights for each epoch

# =====================================
# 5. Topographic Error function
# =====================================
def topographic_error(som, data):
    error = 0

    for x in data:
        dists = np.linalg.norm(som.get_weights() - x, axis=2)

        # Get two best matching units (BMUs)
        winners = np.unravel_index(
            np.argsort(dists, axis=None)[:2],
            dists.shape
        )

        w1 = (winners[0][0], winners[1][0])
        w2 = (winners[0][1], winners[1][1])

        # Check if they are adjacent
        if max(abs(w1[0] - w2[0]), abs(w1[1] - w2[1])) > 1:
            error += 1

    return error / len(data)

# =====================================
# 6. Training loop
# =====================================
epochs = 20

for epoch in range(epochs):
    som.train_random(data, 500)

    # Quantization Error (QE)
    qe = np.mean([
        np.linalg.norm(x - som.get_weights()[som.winner(x)])
        for x in data
    ])

    # Topographic Error (TE)
    te = topographic_error(som, data)

    qe_list.append(qe)
    te_list.append(te)
    som_list.append(som.get_weights().copy())

    print(f"Epoch {epoch}: QE={qe:.4f}, TE={te:.4f}")

# =====================================
# 7. Save trained weights
# =====================================
np.save(r"D:\VECTORS\som_weights.npy", som.get_weights())

print("SOM training completed and weights saved.")


















