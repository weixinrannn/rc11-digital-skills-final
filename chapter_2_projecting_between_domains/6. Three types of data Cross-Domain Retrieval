# =====================================
# Remove similar results
# =====================================
def remove_similar(indices, vectors, threshold=0.90):
    selected = []
    vecs = []

    for i in indices:
        v = vectors[i]
        keep = True

        for sv in vecs:
            sim = np.dot(v, sv) / (np.linalg.norm(v) * np.linalg.norm(sv))
            if sim > threshold:
                keep = False
                break

        if keep:
            selected.append(i)
            vecs.append(v)

    return selected

# =====================================
# Multi-query semantic search
# =====================================
def multi_query_search(queries):

    tokens = clip.tokenize(queries).to(device)

    with torch.no_grad():
        text_features = model.encode_text(tokens)
        text_features /= text_features.norm(dim=-1, keepdim=True)

    text_features = text_features.cpu().numpy()

    def rank(vectors):
        sims = np.dot(vectors, text_features.T)
        sims = sims.max(axis=1)
        return np.argsort(-sims)

    return (
        rank(paint_vectors),
        rank(film_vectors),
        rank(airbnb_vectors)
    )

# =====================================
# Select top results
# =====================================
def select(indices, vectors, names, num=6):

    indices = remove_similar(indices, vectors)

    final = []

    for i in indices:
        path = str(names[i])

        if not os.path.exists(path):
            continue

        final.append(i)

        if len(final) >= num:
            break

    return final

# =====================================
# Save images
# =====================================
def save_images(idxs, names, folder):

    os.makedirs(folder, exist_ok=True)

    for i, idx in enumerate(idxs):
        try:
            shutil.copy(names[idx], os.path.join(folder, f"{i}.jpg"))
        except:
            pass

# =====================================
# Visualization
# =====================================
def show(group_name, p, f, a):

    plt.figure(figsize=(18, 8))
    plt.suptitle(group_name, fontsize=16)

    def draw(row, idxs, names):
        for i, idx in enumerate(idxs):
            img = Image.open(names[idx])
            plt.subplot(3, 6, row * 6 + i + 1)
            plt.imshow(img)
            plt.axis("off")

    draw(0, p, paint_names)
    draw(1, f, film_names)
    draw(2, a, airbnb_names)

    plt.subplot(3, 6, 1)
    plt.title("Paintings", loc="left")

    plt.subplot(3, 6, 7)
    plt.title("Film", loc="left")

    plt.subplot(3, 6, 13)
    plt.title("Airbnb", loc="left")

    plt.tight_layout()
    plt.show()

# =====================================
# Main process
# =====================================
for group_name, queries in query_groups.items():

    print("\nProcessing:", group_name)

    p_all, f_all, a_all = multi_query_search(queries)

    p = select(p_all, paint_vectors, paint_names)
    f = select(f_all, film_vectors, film_names)
    a = select(a_all, airbnb_vectors, airbnb_names)

    base = os.path.join(save_root, group_name)

    save_images(p, paint_names, os.path.join(base, "paintings"))
    save_images(f, film_names, os.path.join(base, "film"))
    save_images(a, airbnb_names, os.path.join(base, "airbnb"))

    show(group_name, p, f, a)

print("\nAll results saved to:", save_root)
