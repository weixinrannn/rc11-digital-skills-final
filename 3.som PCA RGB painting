import numpy as np
import matplotlib.pyplot as plt
from sklearn.decomposition import PCA

# =====================================
# 1. Load vector data
# =====================================
painting_vectors = np.load(r"D:\VECTORS\painting_vectors.npy")

print("Data shape:", painting_vectors.shape)

# =====================================
# 2. Apply PCA (reduce to 3 dimensions)
# =====================================
pca = PCA(n_components=3, whiten=True)
pca_result = pca.fit_transform(painting_vectors)

# =====================================
# 3. Normalize values to [0, 1]
# =====================================
pca_min = pca_result.min(axis=0)
pca_max = pca_result.max(axis=0)

rgb = (pca_result - pca_min) / (pca_max - pca_min)

# =====================================
# 4. Enhance contrast (important)
# =====================================
# Increase intensity
rgb = np.clip(rgb * 1.2, 0, 1)

# Apply smoothing for a softer visual effect
rgb = np.power(rgb, 1.2)

# =====================================
# 5. Reshape into grid
# =====================================
grid_size = int(np.sqrt(len(rgb)))

# Ensure square shape
rgb = rgb[:grid_size * grid_size]

rgb_map = rgb.reshape(grid_size, grid_size, 3)

# =====================================
# 6. Visualization
# =====================================
plt.figure(figsize=(6, 6))
plt.imshow(rgb_map)
plt.title("PCA RGB Visualization (Painting Dataset)")
plt.axis("off")

# =====================================
# 7. Save output
# =====================================
save_path = r"D:\FINAL_RESULTS\som_painting_rgb.png"
plt.savefig(save_path, dpi=300)

print("Saved to:", save_path)

plt.show()
