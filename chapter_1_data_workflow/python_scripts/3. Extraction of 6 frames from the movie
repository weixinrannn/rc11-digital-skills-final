import os
import cv2
import numpy as np
from PIL import Image, ImageDraw, ImageFont, ImageOps

# =========================
# PATH SETTINGS
# =========================
input_root = r"D:\00\film_clips"
output_root = r"D:\00\film_sequence_panels_6frames"
os.makedirs(output_root, exist_ok=True)

# =========================
# PARAMETERS
# =========================
frames_per_video = 6
tile_w = 260
tile_h = 180

margin_x = 50
margin_y = 40
gap_x = 25

title_area_h = 70
time_area_h = 40

bg_color = "white"
text_color = "black"

video_exts = [".mp4", ".mov", ".avi", ".mkv"]

# =========================
# FONT
# =========================
def get_font(size):
    font_candidates = [
        "C:/Windows/Fonts/arial.ttf",
        "C:/Windows/Fonts/Arial.ttf",
        "arial.ttf"
    ]
    for fp in font_candidates:
        try:
            return ImageFont.truetype(fp, size)
        except:
            continue
    return ImageFont.load_default()

title_font = get_font(34)
time_font = get_font(22)

# =========================
# EXTRACT 6 FRAMES
# =========================
def extract_6_frames(video_path, n=6):

    cap = cv2.VideoCapture(video_path)

    if not cap.isOpened():
        print(f"❌ Cannot open video: {video_path}")
        return [], []

    frame_count = int(cap.get(cv2.CAP_PROP_FRAME_COUNT))
    fps = cap.get(cv2.CAP_PROP_FPS)

    if fps is None or fps <= 0:
        fps = 25.0

    if frame_count <= 0:
        print(f"❌ Failed to read frame count: {video_path}")
        cap.release()
        return [], []

    # Uniform sampling
    indices = [round(i * (frame_count - 1) / (n - 1)) for i in range(n)]

    frames = []
    time_labels = []

    for idx in indices:
        cap.set(cv2.CAP_PROP_POS_FRAMES, idx)
        ret, frame = cap.read()

        if not ret or frame is None:
            continue

        frame_rgb = cv2.cvtColor(frame, cv2.COLOR_BGR2RGB)
        frames.append(frame_rgb)

        t = idx / fps
        time_labels.append(f"t={t:.1f}")

    cap.release()
    return frames, time_labels

# =========================
# CREATE PANEL
# =========================
def make_video_panel(video_path, category_name, save_path):

    video_name = os.path.splitext(os.path.basename(video_path))[0]

    frames, time_labels = extract_6_frames(video_path, frames_per_video)

    if len(frames) == 0:
        print(f"⚠️ Skipped: {video_name}")
        return

    n = len(frames)

    canvas_w = margin_x * 2 + n * tile_w + (n - 1) * gap_x
    canvas_h = margin_y * 2 + title_area_h + time_area_h + tile_h

    canvas = Image.new("RGB", (canvas_w, canvas_h), bg_color)
    draw = ImageDraw.Draw(canvas)

    # Title
    title_text = f"{category_name.upper()}  |  {video_name}"
    draw.text((margin_x, margin_y), title_text, fill=text_color, font=title_font)

    y_time = margin_y + title_area_h
    y_img = y_time + time_area_h

    for i, frame_rgb in enumerate(frames):

        img = Image.fromarray(frame_rgb).convert("RGB")

        img = ImageOps.fit(
            img,
            (tile_w, tile_h),
            method=Image.Resampling.LANCZOS,
            centering=(0.5, 0.5)
        )

        x = margin_x + i * (tile_w + gap_x)

        # Time label center
        label = time_labels[i] if i < len(time_labels) else f"{i+1}/6"
        bbox = draw.textbbox((0, 0), label, font=time_font)
        text_w = bbox[2] - bbox[0]

        tx = x + (tile_w - text_w) // 2
        draw.text((tx, y_time), label, fill=text_color, font=time_font)

        canvas.paste(img, (x, y_img))

    canvas.save(save_path, quality=95)
    print(f"✅ Saved: {save_path}")

# =========================
# MAIN LOOP
# =========================
if not os.path.exists(input_root):
    print(f"❌ Path not found: {input_root}")
    exit()

category_folders = [
    d for d in os.listdir(input_root)
    if os.path.isdir(os.path.join(input_root, d))
]

if len(category_folders) == 0:
    print("❌ No category folders found")
    exit()

for category_name in category_folders:

    category_path = os.path.join(input_root, category_name)

    category_output = os.path.join(output_root, category_name)
    os.makedirs(category_output, exist_ok=True)

    video_files = [
        f for f in os.listdir(category_path)
        if os.path.splitext(f)[1].lower() in video_exts
    ]

    if len(video_files) == 0:
        print(f"⚠️ No videos in {category_name}")
        continue

    video_files.sort()

    for vf in video_files:

        video_path = os.path.join(category_path, vf)
        video_name = os.path.splitext(vf)[0]

        save_path = os.path.join(category_output, f"{video_name}_panel.jpg")

        make_video_panel(video_path, category_name, save_path)

print("🔥 All completed")
